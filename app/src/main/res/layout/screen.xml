<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- ROW 1: Enemy -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvEnemyLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enemy" />

        <TextView
            android:id="@+id/tvEnemyHealth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp" />

        <ImageView
            android:id="@+id/imgEnemyDefend"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="16dp"
            android:visibility="gone"
            android:src="@drawable/ic_defend" />
    </LinearLayout>

    <!-- ROW 2: Next Move -->
    <TextView
        android:id="@+id/tvNextMove"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Next Move: ..."
        android:paddingTop="12dp"
        android:paddingBottom="12dp" />

    <!-- ROW 3: Player -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvPlayerLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Player" />

        <TextView
            android:id="@+id/tvPlayerHealth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp" />

        <ImageView
            android:id="@+id/imgPlayerDefend"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="16dp"
            android:visibility="gone"
            android:src="@drawable/ic_defend" />
    </LinearLayout>

    <!-- ROW 4: Input Panel -->
    <LinearLayout
        android:id="@+id/inputPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp">

        <Button
            android:id="@+id/btnAttack"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Attack" />

        <Button
            android:id="@+id/btnDefend"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Defend" />
    </LinearLayout>

</LinearLayout>